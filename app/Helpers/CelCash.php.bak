    {
      
		$token 					= CelCash::Token();
        
        // Query otimizada com filtros específicos e ordenação
		$query = [
			'startAt' 				=> 0,
			'limit' 				=> 100,
			'customerGalaxPayIds' 	=> $customerGalaxPayId,
			'payDayFrom'			=> $payDayFrom,
